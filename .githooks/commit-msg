#!/bin/sh
# Validate commit message follows Conventional Commits format.
# https://www.conventionalcommits.org/
#
# Setup: git config core.hooksPath .githooks
#        (or run: make setup)

MSG=$(cat "$1")
PATTERN="^(feat|fix|docs|style|refactor|perf|test|chore|ci)(\(.+\))?(!)?: .+"

# Skip merge commits
case "$MSG" in
  Merge\ *) exit 0 ;;
  Revert\ *) exit 0 ;;
esac

if ! printf '%s' "$MSG" | grep -qEm1 "$PATTERN"; then
  echo ""
  echo "❌  Commit message không đúng format Conventional Commits!"
  echo ""
  echo "  Format:  <type>(<scope>): <subject>"
  echo "  Types:   feat | fix | docs | style | refactor | perf | test | chore | ci"
  echo ""
  echo "  Ví dụ:"
  echo "    feat(cli): add export command"
  echo "    fix(db): resolve session timeout bug"
  echo "    docs: update installation guide"
  echo "    chore(release): bump version to 1.3.0"
  echo ""
  echo "  Của bạn: $MSG"
  echo ""
  exit 1
fi
